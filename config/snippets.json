{
  "default_routine": "packman",
  "routines": [
    {
      "id": "packman",
      "name": "パックマン周回",
      "description": "パックマンステージ用の周回。ステージ選択、統率力回復分岐、戦闘、EX分岐を細かいスニペットで制御する。",
      "start": "detect_stamina_recover_available",
      "transitions": {
        "detect_stamina_recover_available": [
          {
            "label": "統率力が白なら回復ボタンを押す",
            "if_result": true,
            "next": "tap_stamina_recover_button"
          },
          {
            "label": "統率力が緑なら回復をスキップする",
            "next": "tap_battle_start"
          }
        ],
        "tap_stamina_recover_button": "wait_after_stamina_button_tap",
        "wait_after_stamina_button_tap": "detect_stamina_recover_popup",
        "detect_stamina_recover_popup": [
          {
            "label": "統率力回復ポップアップが出たら回復する",
            "if_result": true,
            "next": "accept_stamina_recover"
          },
          {
            "label": "統率力回復が不要なら戦闘開始を待つ",
            "next": "wait_battle_start"
          }
        ],
        "accept_stamina_recover": "wait_after_stamina_recover",
        "wait_after_stamina_recover": "tap_battle_start",
        "tap_battle_start": "wait_battle_start",
        "wait_battle_start": "wait_initial_money",
        "wait_initial_money": "deploy_unit_slot_4",
        "deploy_unit_slot_4": "wait_battle_progress",
        "wait_battle_progress": "detect_drop_reward",
        "detect_drop_reward": [
          {
            "label": "報酬表示があれば閉じる",
            "if_result": true,
            "next": "dismiss_drop_reward"
          },
          {
            "label": "報酬表示がなければEX判定へ進む",
            "next": "detect_extra_stage"
          }
        ],
        "dismiss_drop_reward": "wait_after_drop_reward",
        "wait_after_drop_reward": "detect_drop_reward",
        "detect_extra_stage": [
          {
            "label": "EXステージが出ていたら挑戦する",
            "if_result": true,
            "next": "accept_extra_stage"
          },
          {
            "label": "EXステージがなければ通常周回へ戻る",
            "next": "return_to_map"
          }
        ],
        "accept_extra_stage": "wait_battle_start",
        "return_to_map": "wait_after_map_return",
        "wait_after_map_return": "detect_stamina_recover_available"
      }
    }
  ],
  "snippets": [
    {
      "id": "return_to_map",
      "name": "マップ帰還",
      "description": "戦闘終了画面の右上にあるマップ帰還ボタンを1回タップする。",
      "steps": [
        {
          "type": "tap",
          "label": "右上のマップ帰還ボタン",
          "enabled": true,
          "x": 610,
          "y": 50,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/battle_end_2.PNG"
        }
      ]
    },
    {
      "id": "tap_battle_start",
      "name": "戦闘開始ボタン押下",
      "description": "ステージ選択画面の「いざ出陣!!」を1回タップする。",
      "detect": {
        "template": "assets/templates/start_battle.png",
        "threshold": 0.88,
        "required": false
      },
      "steps": [
        {
          "type": "tap",
          "label": "戦闘開始ボタン",
          "enabled": true,
          "x": 544,
          "y": 253,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/stage_select.PNG"
        }
      ]
    },
    {
      "id": "wait_after_map_return",
      "name": "マップ帰還後待機",
      "description": "マップ帰還直後の画面描画とタップ受付が安定するまで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "マップ帰還後の安定待ち",
          "seconds": 1.2
        }
      ]
    },
    {
      "id": "detect_stamina_recover_available",
      "name": "統率力回復可能判定",
      "description": "ステージ選択画面の統率力表示が白なら回復可能と判定する。緑のmax(overflow)状態は回復しない。",
      "kind": "condition",
      "detect": {
        "color_probe": {
          "mode": "white_ratio",
          "region": {
            "x": 1090,
            "y": 405,
            "width": 100,
            "height": 30
          },
          "min_rgb": 170,
          "max_delta": 80,
          "min_ratio": 0.02,
          "source_screenshots": [
            "assets/screenshots/stage_select.PNG",
            "assets/screenshots/stage_select_stamina_white.PNG"
          ]
        },
        "required": false
      },
      "steps": []
    },
    {
      "id": "tap_stamina_recover_button",
      "name": "統率力回復ボタン押下",
      "description": "ステージ選択画面の統率力表示部分を1回タップする。",
      "steps": [
        {
          "type": "tap",
          "label": "統率力回復ボタン",
          "enabled": true,
          "x": 546,
          "y": 225,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/stage_select_stamina_white.PNG"
        }
      ]
    },
    {
      "id": "wait_after_stamina_button_tap",
      "name": "統率力回復ボタン後待機",
      "description": "統率力回復確認ポップアップが表示されるまで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "統率力回復ポップアップ待ち",
          "seconds": 0.6
        }
      ]
    },
    {
      "id": "detect_stamina_recover_popup",
      "name": "統率力回復ポップアップ判定",
      "description": "リーダーシップで統率力を全回復する確認ポップアップが表示されているかだけ判定する。",
      "kind": "condition",
      "detect": {
        "template": "assets/templates/packman/stamina_recover_dialog.png",
        "threshold": 0.82,
        "required": false,
        "source_screenshot": "assets/screenshots/stamina_recover_popup.PNG"
      },
      "steps": []
    },
    {
      "id": "accept_stamina_recover",
      "name": "統率力回復を承認",
      "description": "統率力回復ポップアップの「はい」を1回タップする。",
      "detect": {
        "template": "assets/templates/packman/stamina_recover_dialog.png",
        "threshold": 0.82,
        "required": false
      },
      "steps": [
        {
          "type": "tap",
          "label": "統率力回復 はい",
          "enabled": true,
          "x": 268,
          "y": 222,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/stamina_recover_popup.PNG"
        }
      ]
    },
    {
      "id": "wait_after_stamina_recover",
      "name": "統率力回復後待機",
      "description": "統率力回復ポップアップを閉じた後、ステージ選択画面が操作可能になるまで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "統率力回復後待機",
          "seconds": 0.8
        }
      ]
    },
    {
      "id": "wait_battle_start",
      "name": "戦闘開始待機",
      "description": "戦闘画面が操作可能になるまで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "戦闘開始待機",
          "seconds": 3.5
        }
      ]
    },
    {
      "id": "wait_initial_money",
      "name": "初期資金待機",
      "description": "上段右から2つ目のキャラクターを出せる資金が貯まるまで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "初期資金待ち",
          "seconds": 1.2
        }
      ]
    },
    {
      "id": "deploy_unit_slot_4",
      "name": "キャラクター枠4出動",
      "description": "上段右から2つ目のキャラクターを1回タップする。",
      "detect": {
        "template": "assets/templates/deploy_units.png",
        "threshold": 0.88,
        "required": false
      },
      "steps": [
        {
          "type": "tap",
          "label": "キャラクター枠4（上段右から2つ目）",
          "enabled": true,
          "x": 391,
          "y": 260,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/battle.PNG"
        }
      ]
    },
    {
      "id": "wait_battle_progress",
      "name": "戦闘進行待機",
      "description": "キャラクター出動後、戦闘終了表示まで待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "戦闘進行待ち",
          "seconds": 6.0
        }
      ]
    },
    {
      "id": "detect_drop_reward",
      "name": "ドロップ報酬表示判定",
      "description": "ドロップ報酬ダイアログが表示されているかだけ判定する。",
      "kind": "condition",
      "detect": {
        "templates": [
          "assets/templates/packman/drop_reward_top.png",
          "assets/templates/packman/drop_reward_left.png"
        ],
        "threshold": 0.82,
        "required": false,
        "source_screenshot": "assets/screenshots/battle_end_item_gain.PNG"
      },
      "steps": []
    },
    {
      "id": "dismiss_drop_reward",
      "name": "ドロップ報酬表示を閉じる",
      "description": "ドロップ報酬表示が出ている場合に中央付近を1回タップして閉じる。",
      "steps": [
        {
          "type": "tap",
          "label": "ドロップ報酬表示を閉じる",
          "enabled": true,
          "x": 334,
          "y": 240,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/battle_end_item_gain.PNG"
        }
      ]
    },
    {
      "id": "wait_after_drop_reward",
      "name": "報酬表示後待機",
      "description": "ドロップ報酬表示を閉じた後の画面安定を待つ。",
      "steps": [
        {
          "type": "wait",
          "label": "報酬表示後の画面安定待ち",
          "seconds": 0.4
        }
      ]
    },
    {
      "id": "detect_extra_stage",
      "name": "EXステージ出現判定",
      "description": "戦闘終了後にEXステージ挑戦ポップアップが表示されているかだけ判定する。",
      "kind": "condition",
      "detect": {
        "template": "assets/templates/packman/ex_stage_enter_dialog.png",
        "threshold": 0.82,
        "required": false,
        "source_screenshot": "assets/screenshots/ex_stage_enter.PNG"
      },
      "steps": []
    },
    {
      "id": "accept_extra_stage",
      "name": "EXステージ挑戦を承認",
      "description": "EXステージ出現ポップアップの「はい」を1回タップする。",
      "detect": {
        "template": "assets/templates/packman/ex_stage_enter_dialog.png",
        "threshold": 0.82,
        "required": false
      },
      "steps": [
        {
          "type": "tap",
          "label": "EXステージ はい",
          "enabled": true,
          "x": 272,
          "y": 231,
          "duration_seconds": 0.25,
          "coordinate_space": "window",
          "source_screenshot": "assets/screenshots/ex_stage_enter.PNG"
        }
      ]
    }
  ]
}
